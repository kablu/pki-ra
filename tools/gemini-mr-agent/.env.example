# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-thinking-exp    # or gemini-1.5-pro

# ─── GitLab ───────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com                  # or your self-hosted GitLab URL
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_PROJECT_ID=123                          # numeric project id or "namespace/project"

# ─── Agent Behaviour ──────────────────────────────────────────────────────────
AGENT_MAX_TOOL_ROUNDS=10                       # max agentic loop iterations
AGENT_TEMPERATURE=0.2                          # lower = more deterministic
AGENT_VERBOSE=false                            # true = show tool call traces
